# Tax Assistant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Required ---
# Google AI API key for chat (Gemini 2.5 Flash) — https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=your_google_ai_key_here

# Anthropic API key for document extraction (Haiku) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Server Config ---
# Port for the Express API server (default: 4001)
PORT=4001

# Node environment: development | production
NODE_ENV=development

# --- Database ---
# Path to SQLite database file (auto-created on first run)
DB_PATH=data/tax-assistant.db

# --- Authentication ---
# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application) and add http://localhost:3000 to authorized origins
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Usage Limits (token-based, per IP, monthly reset) ---
# Max $ cost per IP per month for main app users (default: $5)
MONTHLY_BUDGET_APP=5
# Max $ cost per IP per month for plugin embeds (default: $1)
MONTHLY_BUDGET_PLUGIN=1

# --- Plugin Mode ---
# Secret key required for iframe/plugin embeds (generate a random string)
PLUGIN_API_KEY=your_plugin_key_here

# --- Production Only ---
# Public URL of the deployed app (used for CORS allowlist in production)
APP_URL=https://ai.smartbizin.com
