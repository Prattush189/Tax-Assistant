# Tax Assistant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Required ---
# Anthropic API key from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your_key_here

# --- Server Config ---
# Port for the Express API server (default: 4001)
PORT=4001

# Node environment: development | production
NODE_ENV=development

# --- Database ---
# Path to SQLite database file (auto-created on first run)
DB_PATH=data/tax-assistant.db

# --- Authentication ---
# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# --- Production Only ---
# Public URL of the deployed app (used for CORS allowlist in production)
APP_URL=https://ai.smartbizin.com
