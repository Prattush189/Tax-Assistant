# Tax Assistant — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git

# --- Required ---
# xAI (Grok) API key — https://console.x.ai
# Used for: chat, notices, AI suggestions
XAI_API_KEY=your_xai_api_key_here

# Google AI (Gemini) API key — https://aistudio.google.com/apikey
# Used for: document extraction (PDF + image uploads)
GEMINI_API_KEY=your_gemini_api_key_here

# --- Server Config ---
# Port for the Express API server (default: 4001)
PORT=4001

# Node environment: development | production
NODE_ENV=development

# --- Database ---
# Path to SQLite database file (auto-created on first run)
DB_PATH=data/tax-assistant.db

# --- Authentication ---
# JWT secrets (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Create an OAuth 2.0 Client ID (Web application) and add http://localhost:3000 to authorized origins
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# --- Plugin Mode ---
# Legacy — kept for backward compatibility
PLUGIN_API_KEY=your_plugin_key_here

# Plugin SSO (v2) — shared HMAC secret with the parent app (ai.smartbizin.com)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# The parent app MUST use the exact same value to sign handshake payloads.
PLUGIN_SSO_SECRET=your_plugin_sso_secret_here

# Comma-separated list of allowed parent origins for the plugin iframe.
# Both the Express CORS allowlist and the client postMessage origin check use this.
PLUGIN_ALLOWED_ORIGINS=https://ai.smartbizin.com

# Same list, exposed to the Vite client. Must match PLUGIN_ALLOWED_ORIGINS in production.
VITE_PLUGIN_ALLOWED_ORIGINS=https://ai.smartbizin.com

# --- Razorpay Payments ---
# Server-side only (NEVER expose Key Secret to the frontend)
# Create keys at: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# Public key exposed to Vite frontend (only Key ID — not secret)
VITE_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# --- Production Only ---
# Public URL of the deployed app (used for CORS allowlist in production)
APP_URL=https://ai.smartbizin.com
